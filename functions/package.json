{
  "name": "divine-temple-functions",
  "version": "1.0.0",
  "description": "Firebase Cloud Functions for Divine Temple payment processing",
  "main": "index.js",
  "scripts": {
    "serve": "firebase emulators:start --only functions",
    "shell": "firebase functions:shell",
    "start": "npm run shell",
    "test": "npm run test:syntax && npm run test:load",
    "test:syntax": "node --check index.js",
    "test:load": "node -e \"require('./index.js'); console.log('Functions module loads successfully');\"",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log"
  },
  "engines": {
    "node": "22"
  },
  "dependencies": {
    "firebase-admin": "^13.8.0",
    "firebase-functions": "^7.2.5",
    "stripe": "^22.1.0"
  },
  "devDependencies": {
    "firebase-functions-test": "^3.4.1"
  },
  "private": true
}
